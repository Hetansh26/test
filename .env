# Copy this file to .env and fill in your values.
# NEVER commit .env — only commit this .env.example file.

# Supabase — server-side (SSR / Cloudflare Workers)
SUPABASE_URL=""
SUPABASE_PUBLISHABLE_KEY=""

# Supabase — client-side (exposed to browser bundle)
VITE_SUPABASE_URL=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_PROJECT_ID=""

# Cashfree — client-side App ID (safe to expose)
VITE_CASHFREE_APP_ID=""

# Cashfree — secret key (server-side ONLY, never use VITE_ prefix here)
CASHFREE_SECRET_KEY=""
